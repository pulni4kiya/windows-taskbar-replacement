<Window x:Class="TaskbarNicifier.App.Views.TaskbarOverlayWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskbarNicifier.App.Views"
        xmlns:vm="clr-namespace:TaskbarNicifier.App.ViewModels"
        xmlns:settings="clr-namespace:TaskbarNicifier.App.Settings"
        xmlns:conv="clr-namespace:TaskbarNicifier.App.Views.Converters"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Taskbar Nicifier"
        Height="80"
        Width="600"
        MinHeight="40"
        MinWidth="320"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        Deactivated="RootWindow_Deactivated"
        PreviewMouseDown="RootWindow_PreviewMouseDown"
        PreviewMouseMove="RootWindow_PreviewMouseMove"
        PreviewMouseLeftButtonUp="RootWindow_PreviewMouseLeftButtonUp">
    <Window.Resources>
        <conv:DoubleToUniformThicknessConverter x:Key="DoubleToUniformThickness" />
        <conv:DoubleToRightMarginConverter x:Key="DoubleToRightMargin" />
        <conv:StripItemTrailingMarginConverter x:Key="StripItemTrailingMargin" />
        <conv:StripGroupTrailingMarginConverter x:Key="StripGroupTrailingMargin" />
        <conv:StripInsertLineBeforeSlotConverter x:Key="StripInsertLineBeforeSlot" />
        <conv:StripInsertLineTailExpandedConverter x:Key="StripInsertLineTailExpanded" />
        <conv:StripInsertLineTailCollapsedConverter x:Key="StripInsertLineTailCollapsed" />
        <conv:ButtonIconSizeConverter x:Key="ButtonIconSize" />
        <conv:AppSlotClickContextConverter x:Key="AppSlotClickContext" />
        <conv:CollapsedGroupClickContextConverter x:Key="CollapsedGroupClickContext" />
        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="ToolTipService.InitialShowDelay" Value="400" />
            <Setter Property="ToolTipService.ShowDuration" Value="20000" />
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate DataType="{x:Type vm:UserGroupViewModel}">
            <Border x:Name="GroupBorder"
                    Padding="2"
                    CornerRadius="10"
                    Background="{Binding GroupBackground}"
                    AllowDrop="True"
                    PreviewDragOver="StripGroup_PreviewDragOver"
                    Drop="StripGroup_Drop">
                <Border.Margin>
                    <MultiBinding Converter="{StaticResource StripGroupTrailingMargin}">
                        <Binding />
                        <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                        <Binding ElementName="RootWindow"
                                 Path="DataContext.Shared.GroupSpacing" />
                        <Binding ElementName="RootWindow"
                                 Path="DataContext.IsStripDragActive" />
                    </MultiBinding>
                </Border.Margin>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility"
                                Value="Visible" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsHiddenGroup}"
                                               Value="True" />
                                    <Condition Binding="{Binding Slots.Count}"
                                               Value="0" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsHiddenGroup}"
                                               Value="False" />
                                    <Condition Binding="{Binding Slots.Count}"
                                               Value="0" />
                                    <Condition Binding="{Binding DataContext.IsStripDragActive, ElementName=RootWindow}"
                                               Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility"
                                        Value="Collapsed" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Move group left"
                                  Command="{Binding DataContext.MoveGroupLeftCommand, Source={x:Reference RootWindow}}"
                                  CommandParameter="{Binding}">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanMoveLeft}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                        <MenuItem Header="Move group right"
                                  Command="{Binding DataContext.MoveGroupRightCommand, Source={x:Reference RootWindow}}"
                                  CommandParameter="{Binding}">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanMoveRight}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Group settings…"
                                  Command="{Binding DataContext.OpenGroupSettingsCommand, Source={x:Reference RootWindow}}"
                                  CommandParameter="{Binding Settings.Id}" />
                        <MenuItem Header="Delete group"
                                  Command="{Binding DataContext.DeleteGroupCommand, Source={x:Reference RootWindow}}"
                                  CommandParameter="{Binding}">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanDeleteGroup}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
                <DockPanel LastChildFill="True">
                    <StackPanel x:Name="ExpandedStrip"
                                Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSingleItemDisplay}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ItemsControl x:Name="AppSlotsItems"
                                      ItemsSource="{Binding Slots}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:AppSlotViewModel}">
                                    <Grid VerticalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0"
                                                   Width="2"
                                                   Margin="0,4,2,4"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Stretch"
                                                   Fill="{Binding DataContext.Shared.StripAccentBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   RadiusX="1"
                                                   RadiusY="1">
                                            <Rectangle.Visibility>
                                                <MultiBinding Converter="{StaticResource StripInsertLineBeforeSlot}">
                                                    <Binding />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                    <Binding ElementName="RootWindow"
                                                             Path="DataContext.StripDragTargetGroupId" />
                                                    <Binding ElementName="RootWindow"
                                                             Path="DataContext.StripDragVisualInsertIndex" />
                                                    <Binding ElementName="RootWindow"
                                                             Path="DataContext.IsStripDragActive" />
                                                </MultiBinding>
                                            </Rectangle.Visibility>
                                        </Rectangle>
                                        <Button Grid.Column="1"
                                                VerticalAlignment="Stretch"
                                                x:Name="AppSlotButton"
                                                Style="{StaticResource IconButtonStyle}"
                                                Padding="0"
                                                PreviewMouseLeftButtonDown="AppSlot_PreviewMouseLeftButtonDown"
                                                PreviewMouseUp="AppSlot_PreviewMouseUp"
                                                PreviewDragEnter="AppSlot_PreviewDragEnter"
                                                PreviewDragOver="AppSlot_PreviewDragOver"
                                                PreviewDragLeave="AppSlot_PreviewDragLeave"
                                                Command="{Binding DataContext.OpenAppSlotMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <Button.Margin>
                                                <MultiBinding Converter="{StaticResource StripItemTrailingMargin}">
                                                    <Binding />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                    <Binding ElementName="RootWindow"
                                                             Path="DataContext.Shared.IconSpacing" />
                                                </MultiBinding>
                                            </Button.Margin>
                                        <Button.CommandParameter>
                                            <MultiBinding Converter="{StaticResource AppSlotClickContext}">
                                                <Binding />
                                                <Binding RelativeSource="{RelativeSource Self}" />
                                            </MultiBinding>
                                        </Button.CommandParameter>
                                        <Button.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="Hide"
                                                          Command="{Binding DataContext.HideAppCommand, Source={x:Reference RootWindow}}"
                                                          CommandParameter="{Binding}" />
                                                <MenuItem Header="Pin to taskbar"
                                                          Command="{Binding DataContext.PinAppCommand, Source={x:Reference RootWindow}}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding CanPinOrUnpin}" Value="True" />
                                                                        <Condition Binding="{Binding IsRunning}" Value="True" />
                                                                        <Condition Binding="{Binding IsPinned}" Value="False" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                                <MenuItem Header="Unpin from taskbar"
                                                          Command="{Binding DataContext.UnpinAppCommand, Source={x:Reference RootWindow}}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding CanPinOrUnpin}" Value="True" />
                                                                        <Condition Binding="{Binding IsPinned}" Value="True" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                                <MenuItem Header="Close all"
                                                          Command="{Binding DataContext.CloseAllAppWindowsCommand, Source={x:Reference RootWindow}}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                                <MenuItem Header="Force kill all"
                                                          Command="{Binding DataContext.ForceKillAllAppWindowsCommand, Source={x:Reference RootWindow}}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                                <Separator />
                                                <MenuItem Header="Move group left"
                                                          Command="{Binding DataContext.MoveGroupLeftCommand, Source={x:Reference RootWindow}}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanMoveGroupLeft}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                                <MenuItem Header="Move group right"
                                                          Command="{Binding DataContext.MoveGroupRightCommand, Source={x:Reference RootWindow}}"
                                                          CommandParameter="{Binding}">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanMoveGroupRight}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                                <Separator />
                                                <MenuItem Header="Group settings…"
                                                          Command="{Binding DataContext.OpenGroupSettingsCommand, Source={x:Reference RootWindow}}"
                                                          CommandParameter="{Binding ParentGroupId}" />
                                                <MenuItem Header="Delete group"
                                                          Command="{Binding DataContext.DeleteGroupCommand, Source={x:Reference RootWindow}}"
                                                          CommandParameter="{Binding ParentGroupId}">
                                                    <MenuItem.Style>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanDeleteParentGroup}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </MenuItem.Style>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.ToolTip>
                                            <StackPanel MaxWidth="420">
                                                <TextBlock Text="{Binding TooltipHeader}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,4" />
                                                <TextBlock Text="{Binding TooltipBody}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Button.ToolTip>
                                        <Grid>
                                            <Border x:Name="FlashOverlay"
                                                    CornerRadius="4"
                                                    BorderThickness="0"
                                                    Background="{Binding DataContext.Shared.FlashBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Opacity="0" />
                                            <Border x:Name="HoverOverlay"
                                                    CornerRadius="4"
                                                    BorderThickness="0"
                                                    Background="#99FFFFFF"
                                                    Opacity="0"
                                                    IsHitTestVisible="False" />
                                            <Border Padding="{Binding DataContext.Shared.IconPadding, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource DoubleToUniformThickness}}">
                                                <Image Source="{Binding Icon}"
                                                       Stretch="Uniform">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Opacity" Value="1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                                                    <Setter Property="Opacity"
                                                                            Value="{Binding DataContext.Shared.PinnedAppOpacity, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                    <Image.Width>
                                                        <MultiBinding Converter="{StaticResource ButtonIconSize}">
                                                            <Binding RelativeSource="{RelativeSource AncestorType=Button}" Path="ActualHeight" />
                                                            <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext.Shared.IconPadding" />
                                                        </MultiBinding>
                                                    </Image.Width>
                                                    <Image.Height>
                                                        <MultiBinding Converter="{StaticResource ButtonIconSize}">
                                                            <Binding RelativeSource="{RelativeSource AncestorType=Button}" Path="ActualHeight" />
                                                            <Binding RelativeSource="{RelativeSource AncestorType=Window}" Path="DataContext.Shared.IconPadding" />
                                                        </MultiBinding>
                                                    </Image.Height>
                                                </Image>
                                            </Border>
                                            <Border Panel.ZIndex="2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    Margin="0,0,2,2"
                                                    Padding="3,0,3,1"
                                                    CornerRadius="8"
                                                    Background="#99000000"
                                                    IsHitTestVisible="False">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding DataContext.Shared.ShowInstanceCountBadge, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                               Value="True" />
                                                                    <Condition Binding="{Binding HasMultipleInstances}"
                                                                               Value="True" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Windows.Count}"
                                                           FontWeight="SemiBold"
                                                           FontSize="{Binding DataContext.Shared.InstanceCountBadgeFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Foreground="{Binding DataContext.Shared.InstanceCountBadgeBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            </Border>
                                        </Grid>
                                    </Button>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=AppSlotButton, Path=IsMouseOver}" Value="True">
                                            <Setter TargetName="HoverOverlay" Property="Opacity" Value="1" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsFlashing}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="FlashStoryboard">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FlashOverlay"
                                                                                       Storyboard.TargetProperty="Opacity">
                                                            <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                                                            <DiscreteDoubleKeyFrame KeyTime="0:0:0.5" Value="0" />
                                                            <DiscreteDoubleKeyFrame KeyTime="0:0:1" Value="1" />
                                                        </DoubleAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="FlashStoryboard" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Rectangle Width="2"
                                   Margin="0,4,0,4"
                                   VerticalAlignment="Stretch"
                                   Fill="{Binding DataContext.Shared.StripAccentBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                   RadiusX="1"
                                   RadiusY="1">
                            <Rectangle.Visibility>
                                <MultiBinding Converter="{StaticResource StripInsertLineTailExpanded}">
                                    <Binding />
                                    <Binding ElementName="RootWindow"
                                             Path="DataContext.StripDragTargetGroupId" />
                                    <Binding ElementName="RootWindow"
                                             Path="DataContext.StripDragVisualInsertIndex" />
                                    <Binding ElementName="RootWindow"
                                             Path="DataContext.IsStripDragActive" />
                                </MultiBinding>
                            </Rectangle.Visibility>
                        </Rectangle>
                        <TextBlock VerticalAlignment="Center"
                                   Margin="8,0,10,0"
                                   Foreground="{Binding DataContext.Shared.StripAccentBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontSize="12"
                                   Text="{Binding Settings.Name}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility"
                                            Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsHiddenGroup}"
                                                           Value="False" />
                                                <Condition Binding="{Binding Slots.Count}"
                                                           Value="0" />
                                                <Condition Binding="{Binding DataContext.IsStripDragActive, ElementName=RootWindow}"
                                                           Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <Button x:Name="CollapsedGroupButton"
                            VerticalAlignment="Stretch"
                            Margin="0"
                            Padding="{Binding DataContext.Shared.IconPadding, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource DoubleToUniformThickness}}"
                            PreviewMouseUp="CollapsedGroup_PreviewMouseUp"
                            Command="{Binding DataContext.OpenCollapsedGroupMenuCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSingleItemDisplay}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.CommandParameter>
                            <MultiBinding Converter="{StaticResource CollapsedGroupClickContext}">
                                <Binding />
                                <Binding RelativeSource="{RelativeSource Self}" />
                            </MultiBinding>
                        </Button.CommandParameter>
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="Move group left"
                                          Command="{Binding DataContext.MoveGroupLeftCommand, Source={x:Reference RootWindow}}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Style>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanMoveLeft}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>
                                <MenuItem Header="Move group right"
                                          Command="{Binding DataContext.MoveGroupRightCommand, Source={x:Reference RootWindow}}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Style>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanMoveRight}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>
                                <MenuItem Header="Unhide all"
                                          Command="{Binding DataContext.UnhideGroupCommand, Source={x:Reference RootWindow}}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Style>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHiddenGroup}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>
                                <MenuItem Header="Unhide app"
                                          ItemsSource="{Binding Slots}">
                                    <MenuItem.Style>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHiddenGroup}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Header" Value="{Binding DisplayName}" />
                                            <Setter Property="Command" Value="{Binding DataContext.UnhideAppCommand, Source={x:Reference RootWindow}}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="Group settings…"
                                          Command="{Binding DataContext.OpenGroupSettingsCommand, Source={x:Reference RootWindow}}"
                                          CommandParameter="{Binding Settings.Id}" />
                                <MenuItem Header="Delete group"
                                          Command="{Binding DataContext.DeleteGroupCommand, Source={x:Reference RootWindow}}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Style>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanDeleteGroup}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </MenuItem.Style>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Button.ToolTip>
                            <TextBlock Text="{Binding Settings.Name}" />
                        </Button.ToolTip>
                        <Grid>
                            <Rectangle Width="2"
                                       Margin="0,4,-2,4"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Stretch"
                                       Fill="{Binding DataContext.Shared.StripAccentBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                       RadiusX="1"
                                       RadiusY="1">
                                <Rectangle.Visibility>
                                    <MultiBinding Converter="{StaticResource StripInsertLineTailCollapsed}">
                                        <Binding />
                                        <Binding ElementName="RootWindow"
                                                 Path="DataContext.StripDragTargetGroupId" />
                                        <Binding ElementName="RootWindow"
                                                 Path="DataContext.StripDragVisualInsertIndex" />
                                        <Binding ElementName="RootWindow"
                                                 Path="DataContext.IsStripDragActive" />
                                    </MultiBinding>
                                </Rectangle.Visibility>
                            </Rectangle>
                            <Grid>
                                <Image Source="{Binding CollapsedIcon}"
                                       Stretch="Uniform">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Opacity"
                                                    Value="1" />
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Slots.Count}"
                                                                   Value="0" />
                                                        <Condition Binding="{Binding DataContext.IsStripDragActive, ElementName=RootWindow}"
                                                                   Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </MultiDataTrigger>
                                                <DataTrigger Binding="{Binding CollapsedIconUsePinnedOpacity}"
                                                             Value="True">
                                                    <Setter Property="Opacity"
                                                            Value="{Binding DataContext.Shared.PinnedAppOpacity, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                    <Image.Width>
                                        <MultiBinding Converter="{StaticResource ButtonIconSize}">
                                            <Binding RelativeSource="{RelativeSource AncestorType=Button}"
                                                     Path="ActualHeight" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Window}"
                                                     Path="DataContext.Shared.IconPadding" />
                                        </MultiBinding>
                                    </Image.Width>
                                    <Image.Height>
                                        <MultiBinding Converter="{StaticResource ButtonIconSize}">
                                            <Binding RelativeSource="{RelativeSource AncestorType=Button}"
                                                     Path="ActualHeight" />
                                            <Binding RelativeSource="{RelativeSource AncestorType=Window}"
                                                     Path="DataContext.Shared.IconPadding" />
                                        </MultiBinding>
                                    </Image.Height>
                                </Image>
                                <TextBlock Text="{Binding Settings.Name}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           MaxWidth="96"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{Binding DataContext.Shared.StripAccentBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                           FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Slots.Count}"
                                                                   Value="0" />
                                                        <Condition Binding="{Binding DataContext.IsStripDragActive, ElementName=RootWindow}"
                                                                   Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border Panel.ZIndex="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,2,2"
                                        Padding="3,0,3,1"
                                        CornerRadius="8"
                                        Background="#99000000"
                                        IsHitTestVisible="False">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding DataContext.Shared.ShowInstanceCountBadge, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                   Value="True" />
                                                        <Condition Binding="{Binding HasMultipleWindowsForCollapsedBadge}"
                                                                   Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding TotalOpenWindowsInGroup}"
                                               FontWeight="SemiBold"
                                               FontSize="{Binding DataContext.Shared.InstanceCountBadgeFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                               Foreground="{Binding DataContext.Shared.InstanceCountBadgeBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Button>
                </DockPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{Binding Shared.TaskbarBrush}"
            CornerRadius="14"
            Padding="0">
        <DockPanel LastChildFill="True" VerticalAlignment="Stretch">
            <Border DockPanel.Dock="Left"
                    Width="12"
                    Background="#15FFFFFF"
                    Cursor="SizeAll"
                    Visibility="{Binding DragHandleVisibility}"
                    ToolTip="Drag window (debug, standalone)">
                <Rectangle Width="2"
                           Height="18"
                           Fill="#55FFFFFF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RadiusX="1"
                           RadiusY="1" />
            </Border>
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button Width="34"
                        Height="34"
                        Margin="10,0,8,0"
                        Command="{Binding OpenSettingsCommand}"
                        x:Name="SettingsButton"
                        ToolTip="Settings">
                    <TextBlock Text="⚙"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>

                <Button Width="34"
                        Height="34"
                        Margin="0,0,0,0"
                        Command="{Binding ToggleModeCommand}"
                        Visibility="{Binding ModeToggleVisibility}"
                        ToolTip="{Binding ModeToolTip}">
                    <TextBlock Text="{Binding ModeGlyph}"
                               FontSize="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </StackPanel>

            <Grid local:WindowDragSuppressor.SuppressWindowDrag="True">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <Border Padding="10,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ItemsControl Grid.Column="0"
                                          HorizontalAlignment="Left"
                                          ItemsSource="{Binding LeftStripGroups}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <Border Grid.Column="1"
                                    Background="Transparent"
                                    VerticalAlignment="Stretch">
                                <Border.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Create group"
                                                  Command="{Binding CreateGroupCommand}" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                            </Border>
                            <ItemsControl Grid.Column="2"
                                          HorizontalAlignment="Right"
                                          ItemsSource="{Binding RightStripGroups}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </ScrollViewer>

                <Popup x:Name="SettingsPopup"
                       IsOpen="{Binding IsSettingsOpen}"
                       StaysOpen="True"
                       PlacementTarget="{Binding ElementName=SettingsButton}"
                       Placement="Top"
                       VerticalOffset="6">
                    <Border x:Name="SettingsPopupRoot"
                            Background="#FFF0F0F0"
                            BorderBrush="#FFCCCCCC"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            MinWidth="280"
                            DataContext="{Binding Shared}">
                        <StackPanel TextElement.Foreground="#FF222222">
                            <TextBlock Text="Settings"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10" />

                            <CheckBox Content="Lock position"
                                      Margin="0,0,0,8"
                                      ToolTip="Prevent resizing the overlay window"
                                      IsChecked="{Binding LockPosition, Mode=TwoWay}" />

                            <CheckBox Content="Show taskbar on each monitor"
                                      Margin="0,0,0,8"
                                      ToolTip="Create one overlay per monitor (each remembers its own position)"
                                      IsChecked="{Binding ShowTaskbarOnAllMonitors, Mode=TwoWay}" />

                            <CheckBox Content="Filter windows by screen"
                                      Margin="0,0,0,8"
                                      ToolTip="If enabled, each monitor's overlay shows only windows on that monitor"
                                      IsChecked="{Binding FilterWindowsByScreen, Mode=TwoWay}" />

                            <TextBlock Text="{Binding IconPadding, StringFormat=Icon padding: {0:0}}" />
                            <Slider Minimum="0"
                                    Maximum="24"
                                    SmallChange="1"
                                    LargeChange="2"
                                    Value="{Binding IconPadding, Mode=TwoWay}" />

                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding IconSpacing, StringFormat=Icon spacing: {0:0}}" />
                            <Slider Minimum="0"
                                    Maximum="30"
                                    SmallChange="1"
                                    LargeChange="2"
                                    Value="{Binding IconSpacing, Mode=TwoWay}" />

                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding GroupSpacing, StringFormat=Group spacing: {0:0}}" />
                            <Slider Minimum="0"
                                    Maximum="48"
                                    SmallChange="1"
                                    LargeChange="2"
                                    Value="{Binding GroupSpacing, Mode=TwoWay}" />

                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding RefreshIntervalMs, StringFormat=Refresh (ms): {0}}" />
                            <Slider Minimum="250"
                                    Maximum="5000"
                                    SmallChange="50"
                                    LargeChange="250"
                                    Value="{Binding RefreshIntervalMs, Mode=TwoWay}" />

                            <TextBlock Margin="0,8,0,0"
                                       Text="App mode" />
                            <ComboBox SelectedValue="{Binding AppMode, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Margin="0,4,0,0">
                                <ComboBoxItem Content="Normal"
                                              Tag="{x:Static settings:AppMode.Normal}" />
                                <ComboBoxItem Content="Debug"
                                              Tag="{x:Static settings:AppMode.Debug}" />
                            </ComboBox>

                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding DragHoverDelaySeconds, StringFormat=Drag hover (s): {0:0.00}}" />
                            <Slider Minimum="0.05"
                                    Maximum="2.0"
                                    SmallChange="0.05"
                                    LargeChange="0.1"
                                    Value="{Binding DragHoverDelaySeconds, Mode=TwoWay}" />

                            <TextBlock Margin="0,8,0,0"
                                       Text="Show pinned apps" />
                            <ComboBox SelectedValue="{Binding PinnedAppsDisplayMode, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Margin="0,4,0,8"
                                      ToolTip="Where to show shortcuts for pinned apps that have no window on this monitor">
                                <ComboBoxItem Content="Where pinned"
                                              Tag="{x:Static settings:PinnedAppsDisplayMode.WherePinned}" />
                                <ComboBoxItem Content="On all screens"
                                              Tag="{x:Static settings:PinnedAppsDisplayMode.AllScreens}" />
                                <ComboBoxItem Content="On main screen"
                                              Tag="{x:Static settings:PinnedAppsDisplayMode.MainScreen}" />
                            </ComboBox>

                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding PinnedAppOpacity, StringFormat=Pinned app opacity: {0:0.00}}" />
                            <Slider Minimum="0.15"
                                    Maximum="1.0"
                                    SmallChange="0.05"
                                    LargeChange="0.1"
                                    Value="{Binding PinnedAppOpacity, Mode=TwoWay}" />

                            <CheckBox Content="Show instance count on app buttons"
                                      Margin="0,10,0,0"
                                      ToolTip="When an app has multiple windows, show a small count on the icon"
                                      IsChecked="{Binding ShowInstanceCountBadge, Mode=TwoWay}" />

                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding InstanceCountBadgeFontSize, StringFormat=Instance badge size: {0:0}}" />
                            <Slider Minimum="6"
                                    Maximum="22"
                                    SmallChange="1"
                                    LargeChange="1"
                                    Value="{Binding InstanceCountBadgeFontSize, Mode=TwoWay}" />

                            <TextBlock Margin="0,8,0,0"
                                       Text="Instance badge color" />
                            <xctk:ColorPicker Margin="0,4,0,0"
                                              SelectedColor="{Binding InstanceCountBadgeColor, Mode=TwoWay}" />

                            <Button Content="New strip group"
                                    Margin="0,10,0,0"
                                    Padding="10,6"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding AddUserStripGroupCommand}"
                                    ToolTip="Adds a new empty group (before Hidden). Drag apps into it." />

                            <TextBlock Margin="0,10,0,0"
                                       Text="Taskbar color" />
                            <xctk:ColorPicker Margin="0,4,0,0"
                                              SelectedColor="{Binding TaskbarColor, Mode=TwoWay}" />

                            <TextBlock Margin="0,10,0,0"
                                       Text="Flash color" />
                            <xctk:ColorPicker Margin="0,4,0,0"
                                              SelectedColor="{Binding FlashColor, Mode=TwoWay}" />

                            <TextBlock Margin="0,10,0,0"
                                       Text="Strip accent — drag line and empty-group name" />
                            <xctk:ColorPicker Margin="0,4,0,0"
                                              SelectedColor="{Binding StripAccentColor, Mode=TwoWay}" />

                            <Button Content="Exit"
                                    Margin="0,14,0,0"
                                    Padding="10,6"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding ExitCommand}"
                                    ToolTip="Close Taskbar Nicifier" />
                        </StackPanel>
                    </Border>
                </Popup>

                <Popup x:Name="GroupSettingsPopup"
                       IsOpen="{Binding IsGroupSettingsOpen, Mode=TwoWay}"
                       StaysOpen="True"
                       PlacementTarget="{Binding ElementName=RootWindow}"
                       Placement="Center"
                       Closed="GroupSettingsPopup_OnClosed">
                    <Border x:Name="GroupSettingsPopupRoot"
                            Background="#FFF8F8F8"
                            BorderBrush="#FFCCCCCC"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            MinWidth="320">
                        <StackPanel TextElement.Foreground="#FF222222">
                            <TextBlock Text="Group settings"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10" />

                            <TextBlock Text="Name" />
                            <TextBox Text="{Binding EditingGroupDisplayName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,4,0,8"
                                     Background="#FFFFFFFF"
                                     Foreground="#FF222222"
                                     BorderBrush="#FFAAAAAA" />

                            <TextBlock Text="Background color" />
                            <xctk:ColorPicker Margin="0,4,0,8"
                                              SelectedColor="{Binding EditingGroupColor, Mode=TwoWay}" />
                            <Border Height="28"
                                    Margin="0,0,0,8"
                                    CornerRadius="4"
                                    BorderBrush="#FFAAAAAA"
                                    BorderThickness="1"
                                    Background="{Binding EditingGroupBrushPreview}" />

                            <TextBlock Text="Display type" />
                            <ComboBox Margin="0,4,0,0"
                                      ItemsSource="{Binding AllGroupDisplayTypes}"
                                      SelectedItem="{Binding EditingGroupDisplayType, Mode=TwoWay}"
                                      Background="#FFFFFFFF"
                                      Foreground="#FF222222" />

                            <Button Content="Done"
                                    Margin="0,14,0,0"
                                    Padding="10,6"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding CloseGroupSettingsCommand}" />
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </DockPanel>
    </Border>
</Window>
